{
  "name": "@opspulse/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @opspulse/shared build && vite",
    "build": "pnpm --filter @opspulse/shared build && tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "pnpm --filter @opspulse/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opspulse/shared": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
