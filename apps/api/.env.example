NODE_ENV=development
HOST=127.0.0.1
PORT=3000
API_PREFIX=api/v1
# Browser clients must match an exact origin. Add http://127.0.0.1:5173 if
# you open the Vite web app through 127.0.0.1 instead of localhost.
CORS_ORIGINS=http://localhost:5173
SERVICE_NAME=OpsPulse API
LOG_LEVEL=log
REQUEST_BODY_LIMIT=1mb

POSTGRES_USER=opspulse
POSTGRES_PASSWORD=opspulse_dev
POSTGRES_DB=opspulse
POSTGRES_PORT=5432
DATABASE_URL=postgresql://opspulse:opspulse_dev@localhost:5432/opspulse?schema=public

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=opspulse-api
JWT_AUDIENCE=opspulse-clients
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
PASSWORD_HASH_ROUNDS=12
DEMO_USER_PASSWORD=OpsPulseDemo123!

# Web app:
# VITE_API_URL should point to the API origin, without /api/v1.
VITE_API_URL=http://localhost:3000
VITE_API_BASE_PATH=api/v1

# Mobile app:
# iOS simulator can usually reach the local API through 127.0.0.1.
# Android emulator usually needs http://10.0.2.2:3000.
# A physical device must use your development machine's reachable LAN address.
API_URL=http://127.0.0.1:3000
